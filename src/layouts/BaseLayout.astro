---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'The Concord Review: counselor intelligence brief',
  description = 'A counselor-facing intelligence and submission guide for The Concord Review, the peer-reviewed quarterly for secondary-school history essays.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta name="theme-color" content="#7a1e2b" />
  </head>
  <body class="bg-paper text-ink-900 antialiased font-serif">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:bg-accent focus:text-white focus:px-3 focus:py-2 focus:rounded">
      Skip to content
    </a>
    <header class="border-b border-ink-300/60 bg-paper-warm/70">
      <div class="mx-auto max-w-5xl px-6 py-5 flex items-center justify-between">
        <a href="/" class="font-display font-semibold tracking-tight text-ink-900 text-lg">
          The Concord Review, Counselor Brief
        </a>
        <nav aria-label="Section navigation" class="hidden md:block">
          <ul class="flex gap-5 text-sm font-sans text-ink-500">
            <li><a class="hover:text-accent-dark" href="#about">About</a></li>
            <li><a class="hover:text-accent-dark" href="#status">Status</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="border-t border-ink-300/60 mt-16 bg-paper-warm/40">
      <div class="mx-auto max-w-5xl px-6 py-8 text-sm font-sans text-ink-500 space-y-2">
        <p>
          Maintained by Counselor Jay. This site is an independent counselor-facing brief, not affiliated with The Concord Review. Always verify submission requirements and fees on The Concord Review's own website at the moment of submission.
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html { scroll-behavior: smooth; }
  :target { scroll-margin-top: 5rem; }
  body { font-feature-settings: "kern", "liga", "onum"; }
  h1, h2, h3, h4 { font-feature-settings: "kern", "liga"; }
</style>
