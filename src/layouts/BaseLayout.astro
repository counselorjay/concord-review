---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'The Concord Review: counselor intelligence brief',
  description = 'A counselor-facing intelligence and submission guide for The Concord Review, the peer-reviewed quarterly for secondary-school history essays.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta name="theme-color" content="#10182a" />
  </head>
  <body id="top">
    <a href="#main" class="skiplink">Skip to content</a>
    <nav class="topbar"><div class="topbar-inner">
      <a href="#top" class="brand">The Concord Review, Counselor Brief</a>
      <a href="#brief">Brief</a>
      <a href="#examples">Examples</a>
      <a href="#coach-note">Coach's Note</a>
      <a href="#about">About</a>
    </div></nav>
    <main id="main">
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <p>Built by Counselor Jay, The Admission Masters, concord.counselorjay.com.</p>
        <p>Sources: Concord Review public archive (tcr.org) and Wayback Machine snapshots. This site is an independent counselor-facing brief, not affiliated with The Concord Review. Always verify submission requirements and fees on The Concord Review's own website at the moment of submission.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
:root {
  --text: #202124;
  --muted: #6f7480;
  --line: #e4e6eb;
  --soft: #f7f7f8;
  --pill: #ffffff;
  --green: #10b981;
  --gold-bg: #fff7df;
  --gold-line: #f1c66d;
  --navy: #1f2a44;
  --accent: #7a1e2b;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
:target { scroll-margin-top: 84px; }
body {
  margin: 0;
  font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  color: var(--text);
  background: #fff;
  line-height: 1.55;
  font-size: 14px;
}
a { color: inherit; }
.skiplink { position: absolute; left: -9999px; }
.skiplink:focus { left: 12px; top: 12px; background: var(--accent); color: #fff; padding: 8px 12px; border-radius: 6px; z-index: 100; }

.topbar {
  border-bottom: 1px solid var(--line);
  background: rgba(255,255,255,.94);
  position: sticky;
  top: 0;
  z-index: 10;
}
.topbar-inner, main, .footer-inner { max-width: 1370px; margin: 0 auto; padding: 0 28px; }
.topbar-inner { height: 64px; display: flex; align-items: center; gap: 26px; }
.topbar a { color: #555963; text-decoration: none; font-size: 14px; }
.topbar a:hover { color: var(--accent); }
.topbar a.brand { color: #202124; font-weight: 600; font-size: 15px; margin-right: auto; }

main { padding-top: 18px; padding-bottom: 18px; }

.hero { margin: 56px 0 48px; max-width: 760px; }
h1 { font-size: 32px; line-height: 1.1; margin: 0 0 14px; letter-spacing: 0; font-weight: 650; }
.hero p.lede { font-size: 17px; color: #4f535d; margin: 0 0 18px; line-height: 1.5; }
.badges { display: flex; gap: 8px; flex-wrap: wrap; }
.badge {
  display: inline-flex; align-items: center; gap: 7px;
  border: 1px solid #dfe2e7; border-radius: 999px; background: var(--pill);
  color: #4f535d; padding: 6px 13px; font-size: 13px;
}
.dot { width: 7px; height: 7px; background: var(--green); border-radius: 50%; }

section.block { margin: 38px 0; }
.section-head {
  display: flex; justify-content: space-between; align-items: end;
  border-bottom: 1px solid var(--line); padding-bottom: 14px; margin-bottom: 16px;
  gap: 16px; flex-wrap: wrap;
}
h2 { font-size: 26px; margin: 0 0 4px; font-weight: 650; letter-spacing: -0.005em; }
h3 { font-size: 17px; margin: 0 0 4px; font-weight: 650; }
h4 { font-size: 14px; margin: 0 0 4px; font-weight: 650; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); }
.section-head .meta { color: var(--muted); font-size: 13px; margin: 0; }

.prose { max-width: 78ch; }
.prose p { margin: 10px 0; font-size: 14px; line-height: 1.6; color: #2c2f37; }
.prose ul { margin: 10px 0; padding-left: 18px; }
.prose ul li { margin: 6px 0; line-height: 1.55; }
.callout {
  border-left: 3px solid var(--accent);
  background: #faf6f7;
  padding: 10px 14px;
  margin: 14px 0;
  font-size: 14px;
  color: #2c2f37;
}

.kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin: 14px 0; }
.kpi { border: 1px solid var(--line); border-radius: 6px; padding: 10px 14px; background: #fff; }
.kpi .num { font-size: 22px; font-weight: 700; color: #1a1d24; font-variant-numeric: tabular-nums; }
.kpi .label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; margin-top: 2px; }

.dist-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.dist-card { border: 1px solid var(--line); border-radius: 6px; padding: 12px 14px; background: #fff; }
.dist-card h4 { color: var(--muted); }
.dist-card table { width: 100%; border-collapse: collapse; margin-top: 6px; font-size: 13px; }
.dist-card td { padding: 4px 0; border-bottom: 1px solid var(--line); }
.dist-card td:last-child { text-align: right; font-weight: 600; font-variant-numeric: tabular-nums; }
.dist-card tr:last-child td { border-bottom: none; }

.heatmap { margin: 12px 0 4px; }
.heatmap table { border-collapse: separate; border-spacing: 3px; font-size: 12px; }
.heatmap th { font-size: 10px; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); font-weight: 600; padding: 4px 6px; text-align: center; }
.heatmap th.row { text-align: right; padding-right: 8px; white-space: nowrap; }
.heatmap td { width: 56px; height: 32px; text-align: center; font-weight: 650; font-size: 13px; border-radius: 4px; font-variant-numeric: tabular-nums; }
.heatmap-note { color: var(--muted); font-size: 12px; margin: 8px 0 0; max-width: 80ch; line-height: 1.5; }

.spot-list { list-style: none; padding: 0; margin: 10px 0 0; }
.spot-list li { padding: 6px 0; border-bottom: 1px dotted var(--line); font-size: 13px; line-height: 1.45; }
.spot-list li:last-child { border-bottom: none; }
.spot-list em { color: var(--muted); font-style: normal; font-size: 12px; margin-left: 4px; }

.authors-grid { display: grid; grid-template-columns: 1fr 1fr 1.4fr; gap: 18px; }
.authors-grid h3 { font-size: 13px; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); font-weight: 600; margin-bottom: 6px; }
.authors-grid p.note { font-size: 12px; color: var(--muted); margin: 4px 0 8px; }
.bar-list { list-style: none; padding: 0; margin: 0; }
.bar-list li { display: grid; grid-template-columns: 70px 1fr 36px; gap: 8px; align-items: center; padding: 4px 0; font-size: 13px; }
.bar-list .lbl { font-weight: 600; color: #1a1d24; }
.bar-list .bar { height: 12px; background: #eef0f3; border-radius: 2px; overflow: hidden; }
.bar-list .bar > span { display: block; height: 100%; background: var(--navy); }
.bar-list .bar.accent > span { background: var(--accent); }
.bar-list .num { text-align: right; font-weight: 600; font-variant-numeric: tabular-nums; color: #1a1d24; }
.school-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.school-table th { text-align: left; padding: 4px 6px; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid var(--line); }
.school-table td { padding: 4px 6px; border-bottom: 1px solid var(--line); line-height: 1.3; }
.school-table td.num { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; }
.school-table td.read a { color: var(--accent); text-decoration: none; font-weight: 600; }
.school-table td.read a:hover { text-decoration: underline; }
.school-table tr:last-child td { border-bottom: none; }

.fail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.fail-card { border: 1px solid var(--line); border-radius: 6px; padding: 12px 14px; background: #fff; }
.fail-card .name { font-weight: 700; font-size: 13px; color: #1a1d24; margin-bottom: 4px; }
.fail-card p { margin: 4px 0; font-size: 13px; line-height: 1.5; color: #2c2f37; }
.fail-card .trap { color: var(--muted); }

.timeline-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 8px; }
.timeline-table th { text-align: left; padding: 8px 12px; color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid var(--line); }
.timeline-table td { padding: 10px 12px; border-bottom: 1px solid var(--line); vertical-align: top; line-height: 1.45; }
.timeline-table td.weeks { white-space: nowrap; font-weight: 600; color: #1a1d24; width: 80px; }
.timeline-table td.phase { font-weight: 600; color: #1a1d24; width: 240px; }
.timeline-table tr.risk { background: var(--gold-bg); border-left: 3px solid var(--gold-line); }
.timeline-table tr.risk td.weeks { color: #7a1e2b; }
.timeline-table tr:last-child td { border-bottom: none; }

.voice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.voice-card { border: 1px solid var(--line); border-radius: 6px; padding: 12px 14px; background: #fff; }
.voice-card.right { border-left: 3px solid var(--green); }
.voice-card.wrong { border-left: 3px solid #d4a3a3; background: #fafafa; }
.voice-card h4 { color: var(--muted); margin-bottom: 8px; }
.voice-card.right h4 span { color: var(--green); }
.voice-card.wrong h4 span { color: #b14040; }
.voice-card blockquote { margin: 6px 0; padding: 6px 0 6px 12px; border-left: 2px solid var(--line); font-style: italic; font-size: 13px; line-height: 1.5; color: #2c2f37; }
.voice-card .why { font-size: 12px; color: var(--muted); margin-top: 6px; line-height: 1.5; }

.examples-table { display: grid; grid-template-columns: 60px minmax(220px, 1.4fr) minmax(140px, .8fr) minmax(160px, .9fr) 100px 90px 80px 80px; gap: 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
.examples-header, .examples-row { display: contents; }
.examples-header > span { padding: 9px 10px; font-size: 10px; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); border-bottom: 1px solid var(--line); background: #fafbfc; font-weight: 600; }
.examples-row > span, .examples-row > a { padding: 12px 10px; min-height: 50px; display: flex; align-items: center; font-size: 13px; line-height: 1.35; border-bottom: 1px solid var(--line); color: #2c2f37; text-decoration: none; }
.examples-row:hover > span, .examples-row:hover > a { background: var(--soft); }
.examples-row > span.title { font-style: italic; font-weight: 500; color: #1a1d24; }
.examples-row > span.year { font-variant-numeric: tabular-nums; font-weight: 600; }
.examples-row > a.read { color: var(--accent); font-weight: 600; }
.examples-row > a.read:hover { text-decoration: underline; }

.checklist { border: 1px solid var(--line); border-radius: 6px; padding: 14px 16px; background: var(--soft); margin: 10px 0; }
.checklist h3 { margin-bottom: 8px; }
.checklist ul { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 6px 14px; }
.checklist li { font-size: 13px; line-height: 1.45; padding-left: 18px; position: relative; }
.checklist li::before { content: ""; position: absolute; left: 0; top: 6px; width: 10px; height: 10px; border: 1px solid var(--green); border-radius: 2px; background: #fff; }

.coach-note { border-left: 4px solid var(--navy); background: #fafbfd; padding: 18px 22px; margin: 14px 0 10px; max-width: 80ch; }
.coach-note p { font-size: 14px; line-height: 1.6; margin: 8px 0; color: #2c2f37; }
.coach-note .sig { font-style: italic; color: var(--muted); text-align: right; margin-top: 14px; font-size: 13px; }

.about { color: var(--muted); font-size: 13px; max-width: 78ch; line-height: 1.55; }

footer { color: var(--muted); text-align: center; padding: 36px 20px; border-top: 1px solid var(--line); margin-top: 48px; font-size: 12px; }
footer p { margin: 4px 0; }

@media (max-width: 900px) {
  .kpi-row, .dist-grid { grid-template-columns: 1fr 1fr; }
  .authors-grid { grid-template-columns: 1fr; }
  .fail-grid, .voice-grid { grid-template-columns: 1fr; }
  .examples-table { display: block; }
  .examples-header { display: none; }
  .examples-row { display: grid; grid-template-columns: 60px 1fr 80px; gap: 4px; padding: 10px 0; border-bottom: 1px solid var(--line); }
  .examples-row > span, .examples-row > a { border-bottom: none; padding: 2px 4px; min-height: 0; }
  .examples-row > span.title { grid-column: 2 / -1; }
  .examples-row > span.author, .examples-row > span.school, .examples-row > span.topic, .examples-row > span.era, .examples-row > span.length { grid-column: 1 / -1; color: var(--muted); font-size: 12px; }
  .checklist ul { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .kpi-row, .dist-grid { grid-template-columns: 1fr; }
  .topbar-inner { gap: 14px; overflow-x: auto; }
  h1 { font-size: 28px; }
}
</style>
</html>
